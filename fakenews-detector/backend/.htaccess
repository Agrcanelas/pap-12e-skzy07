# Passar o header Authorization ao PHP (necessário no XAMPP/Apache)
RewriteEngine On
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# Permitir todos os métodos HTTP (GET, POST, DELETE, etc.)
<LimitExcept GET POST PUT DELETE OPTIONS>
    Deny from all
</LimitExcept>

# CORS preflight
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]
